{
  "version": 2,
  "builds": [
    {
      "src": "nayalumiere-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/nayalumiere-backend/server.js"
    }
  ]
}